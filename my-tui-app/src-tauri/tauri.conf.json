{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pokedex",
  "version": "0.3.0",
  "identifier": "com.tradix.pokedex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pokedex",
        "decorations": false,
        "fullscreen": false,
        "resizable": true,
        "width": 900,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins" : {
    "process": {},
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
